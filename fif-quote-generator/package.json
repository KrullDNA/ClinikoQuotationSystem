{
  "name": "fif-quote-generator",
  "version": "1.0.0",
  "description": "FIF Quote Generator - Feet in Focus Cliniko Quote Management",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "build:renderer": "npm run build:css && npm run build:jsx",
    "build:jsx": "esbuild src/renderer/App.jsx --bundle --outfile=src/renderer/bundle.js --platform=browser --target=chrome120 --loader:.jsx=jsx",
    "build:css": "tailwindcss -i ./src/renderer/styles/input.css -o ./src/renderer/styles/output.css",
    "build:dist": "electron-builder",
    "dev": "concurrently \"npm run build:css -- --watch\" \"npm run build:jsx -- --watch\" \"electron .\""
  },
  "author": "Feet in Focus <info@feetinfocus.com.au>",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.4",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "electron-store": "^8.2.0",
    "node-machine-id": "^1.1.12",
    "puppeteer-core": "^24.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.feetinfocus.quote-generator",
    "productName": "FIF Quote Generator",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
