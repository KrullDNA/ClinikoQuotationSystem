{
  "name": "fif-quote-generator",
  "version": "1.0.0",
  "description": "FIF Quote Generator - Feet in Focus Cliniko Quote Management",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "build:renderer": "npm run build:css && npm run build:jsx",
    "build:jsx": "esbuild src/renderer/App.jsx --bundle --outfile=src/renderer/bundle.js --platform=browser --target=chrome120 --loader:.jsx=jsx",
    "build:css": "tailwindcss -i ./src/renderer/styles/input.css -o ./src/renderer/styles/output.css",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:dist": "npm run build:renderer && electron-builder",
    "dev": "concurrently \"npm run build:css -- --watch\" \"npm run build:jsx -- --watch\" \"electron .\""
  },
  "author": "Feet in Focus <info@feetinfocus.com.au>",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/KrullDNA/ClinikoQuotationSystem.git"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.4",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "electron-store": "^8.2.0",
    "form-data": "^4.0.5",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.feetinfocus.quotegenerator",
    "productName": "FIF Quote Generator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/renderer/App.jsx",
      "!src/renderer/components/**/*.jsx",
      "!src/renderer/utils/**/*.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraResources": []
  }
}
